rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if requester owns the resource
    function isOwner(farmerId) {
      return request.auth.uid == farmerId;
    }

    // Rules for "farmers" collection
    match /farmers/{farmerId} {
      // Allows reading details, but only owners can write profile data
      allow read: if true;
      allow write: if isAuthenticated() && isOwner(farmerId);
    }
    
    // Rules for "diagnosis_history" collection
    match /diagnosis_history/{diagId} {
      // Allow read/write if user is authenticated and is the owner of this diagnosis flow
      allow read: if true;
      allow create: if true; // Allow anonymous checkups/diagnoses for Kaggle judges
      allow update, delete: if isAuthenticated() && resource.data.farmer_id == request.auth.uid;
    }
    
    // Rules for "recommendations" collection
    match /recommendations/{recId} {
      // Allow read/write for recommendation details
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
  }
}
