# FarmCare AI - Environment Variables Template
# Copy this file to .env and fill in your keys

# Google Gemini API Key
GOOGLE_API_KEY=AIzaSy...

# Firebase Configuration JSON (Base64 encoded or inline string)
# Leave empty to run the FastAPI server in offline Demo Mode using local SQLite/In-memory databases.
FIREBASE_CONFIG=

# Firebase Storage Bucket name (e.g. farmcare-ai.appspot.com)
FIREBASE_STORAGE_BUCKET=

# Optional Weather API Key (e.g., OpenWeatherMap)
WEATHER_API_KEY=
